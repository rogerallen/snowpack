# Server Port
PORT=3001

# Logging level (info, debug, warn, error)
LOG_LEVEL=info

# Backend Caching (in seconds) - Default: 2592000 (30 days)
# Determines how long the server stores station data before re-fetching
SERVER_CACHE_STALE_SECONDS=2592000

# Upstream API Endpoint for SNOTEL data
UPSTREAM_API_URL=https://powderlines.kellysoftware.org/api/station

# Frontend API URL - Used by the Vite client to connect to the backend
# Must be accessible from the browser
VITE_API_BASE_URL=http://localhost:3001
