# Server Configuration
PORT=3001
LOG_LEVEL=info

# Backend Caching & Processing (v4)
# Number of days in each sampling interval (default: 3)
SAMPLING_INTERVAL_DAYS=3

# Threshold for detecting sensor failure (consecutive days of 0.0)
ZERO_DETECTION_THRESHOLD_DAYS=14

# Protection window for zero-detection (MM-DD)
ZERO_PROTECTION_START=10-01
ZERO_PROTECTION_END=05-31

# Upstream API URL
# The source for NRCS SNOTEL data (Powderlines API).
UPSTREAM_API_URL=https://powderlines.kellysoftware.org/api/station

# Frontend Configuration
# The base URL for the backend API, accessed by the Vite client.
VITE_API_BASE_URL=http://localhost:3001
